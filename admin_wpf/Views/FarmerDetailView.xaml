<UserControl x:Class="ShetMitraAdmin.Views.FarmerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShetMitraAdmin.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:FarmerDetailViewModel, IsDesignTimeCreatable=True}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBg}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:FarmerDetailViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <TextBlock Text="Farmer Detail"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="8,8,0,8" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding FarmerName}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Village}" Foreground="{StaticResource TextMuted}" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Registered crop: " Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding RegisteredCrop}" Margin="6,0,16,0" FontWeight="SemiBold" />
                        <TextBlock Text="Registered acres: " Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding RegisteredFieldSize}" Margin="6,0,0,0" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AMED Intelligence section (SDD §7 Agent 6 Change 1) -->
            <Border Style="{StaticResource Card}"
                    BorderBrush="{Binding IsAnyMismatch, Converter={StaticResource MismatchToBrushConverter}}"
                    BorderThickness="2">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="AMED Intelligence"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <Border DockPanel.Dock="Right"
                                Background="{StaticResource BrandAccent}"
                                CornerRadius="10"
                                Padding="8,3">
                            <TextBlock Foreground="Black" FontWeight="SemiBold" FontSize="12">
                                <Run Text="Confidence " />
                                <Run Text="{Binding AmedConfidence, StringFormat={}{0:P0}}" />
                            </TextBlock>
                        </Border>
                    </DockPanel>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AMED crop type" Style="{StaticResource CardTitle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AmedCropType}" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="AMED field size (acres)" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding AmedFieldSize}" FontWeight="SemiBold" />
                            <TextBlock Text=" vs registered " Foreground="{StaticResource TextMuted}" />
                            <TextBlock Text="{Binding RegisteredFieldSize}" FontWeight="SemiBold" />
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sowing date" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AmedSowingDate}" FontWeight="SemiBold" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Predicted harvest" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AmedHarvestDate}" FontWeight="SemiBold" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Growth stage / last irrigation" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding AmedGrowthStage}" FontWeight="SemiBold" />
                            <TextBlock Text="  /  " Foreground="{StaticResource TextMuted}" />
                            <TextBlock Text="{Binding AmedLastIrrigation}" FontWeight="SemiBold" />
                        </StackPanel>

                        <!-- Variety details (May 2026 spec) -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Variety" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding Variety}" FontWeight="SemiBold" />
                            <Border Background="{Binding VarietySource, Converter={StaticResource VarietyStatusToBrushConverter}}"
                                    CornerRadius="8"
                                    Padding="6,1"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding VarietySource}"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Brix target" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding BrixTargetMin}" FontWeight="SemiBold" />
                            <TextBlock Text=" – " />
                            <TextBlock Text="{Binding BrixTargetMax}" FontWeight="SemiBold" />
                        </StackPanel>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Collection status" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <Border Grid.Row="7" Grid.Column="1"
                                Background="{Binding VarietyCollectionStatus, Converter={StaticResource VarietyStatusToBrushConverter}}"
                                CornerRadius="8"
                                Padding="8,2"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0">
                            <TextBlock Text="{Binding VarietyCollectionStatus}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="11" />
                        </Border>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Revenue potential" Style="{StaticResource CardTitle}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="₹" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RevenuePotentialInr, StringFormat={}{0:N0}}" FontWeight="SemiBold" />
                            <TextBlock Foreground="{StaticResource Success}"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       Visibility="{Binding IsPremiumVariety, Converter={StaticResource BoolToVis}}">
                                <Run Text="(+" />
                                <Run Text="{Binding PremiumPct}" />
                                <Run Text="% premium)" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsAnyMismatch, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="{StaticResource Danger}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap">
                            <Run Text="Mismatch detected — review farmer registration. " />
                            <Run Text="Area diff: " />
                            <Run Text="{Binding AreaMismatchPct, StringFormat={}{0:0.0}%}" />
                            <Run Text=", crop mismatch: " />
                            <Run Text="{Binding CropMismatch}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Mango Intelligence sub-section (May 2026 — Mango Agent 8 §9.2).
                         Visible only when AMED crop or registered crop is Mango. -->
                    <Border Margin="0,16,0,0"
                            Padding="12"
                            CornerRadius="6"
                            Background="#FFF8E1"
                            BorderBrush="#FFB300"
                            BorderThickness="1"
                            Visibility="{Binding IsMangoFarmer, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Mango Intelligence"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <Border DockPanel.Dock="Right"
                                        Background="#2E7D32"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        Margin="6,0,0,0"
                                        Visibility="{Binding IsAlphonsoGiTagged, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Konkan GI"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border DockPanel.Dock="Right"
                                        Background="{Binding BearingYear, Converter={StaticResource BearingToBrushConverter}}"
                                        CornerRadius="10"
                                        Padding="8,3">
                                    <TextBlock Foreground="#1B1B1B"
                                               FontSize="11"
                                               FontWeight="SemiBold">
                                        <Run Text="Bearing " />
                                        <Run Text="{Binding BearingYear, FallbackValue='UNKNOWN'}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding BearingConfidence, StringFormat={}{0:P0}, FallbackValue='—'}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </Border>
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Flowering detected" Style="{StaticResource CardTitle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FloweringDetected}" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Fruit set detected" Style="{StaticResource CardTitle}" Margin="0,6,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FruitSetDetected}" FontWeight="SemiBold" Margin="0,6,0,0" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tree count" Style="{StaticResource CardTitle}" Margin="0,6,0,0" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TreeCount, FallbackValue='—'}" FontWeight="SemiBold" Margin="0,6,0,0" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Tree age (yrs)" Style="{StaticResource CardTitle}" Margin="0,6,0,0" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TreeAgeYears, FallbackValue='—'}" FontWeight="SemiBold" Margin="0,6,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="3-year crop history"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding AmedHistory}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              GridLinesVisibility="None"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Season"  Binding="{Binding Season}"  Width="*" />
                            <DataGridTextColumn Header="Crop"    Binding="{Binding Crop}"    Width="*" />
                            <DataGridTextColumn Header="Sowing"  Binding="{Binding Sowing}"  Width="*" />
                            <DataGridTextColumn Header="Harvest" Binding="{Binding Harvest}" Width="*" />
                            <DataGridTextColumn Header="Acres"   Binding="{Binding Acres}"   Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

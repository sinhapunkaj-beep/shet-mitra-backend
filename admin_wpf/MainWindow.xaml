<Window x:Class="ShetMitraAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShetMitraAdmin.ViewModels"
        xmlns:views="clr-namespace:ShetMitraAdmin.Views"
        Title="ShetMitra Admin"
        Height="800" Width="1280"
        Background="{StaticResource SurfaceBg}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1B5E20">
            <StackPanel>
                <TextBlock Text="ShetMitra"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="20,24,0,24" />

                <ListBox Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         SelectedIndex="{Binding SelectedTabIndex}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="20,12" />
                            <Setter Property="Foreground" Value="#E8F5E9" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2E7D32" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="Dashboard" />
                    <ListBoxItem Content="Farmers" />
                    <ListBoxItem Content="Alerts" />
                    <ListBoxItem Content="Analytics" />
                    <ListBoxItem Content="Price Analysis" />
                    <ListBoxItem Content="Trader Intelligence" />
                    <ListBoxItem Content="Marketplace" />
                    <ListBoxItem Content="Belt Intelligence" />
                    <ListBoxItem Content="Drone Operations" />
                </ListBox>
            </StackPanel>
        </Border>

        <Frame Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Content="{Binding CurrentView}" />
    </Grid>
</Window>
